# ================================================================
# Sponge RCA Platform - Environment Variables
# ================================================================
#
# Copy this file to .env and fill in your configuration:
#   cp .env.example .env
#
# ================================================================

# ================================================================
# PostgreSQL Database Configuration
# ================================================================
POSTGRES_USER=sponge
POSTGRES_PASSWORD=sponge_secure_password_change_me
POSTGRES_DB=sponge
POSTGRES_PORT=5432

# ================================================================
# Application Configuration
# ================================================================
SPONGE_MODE=soap  # Options: cli, monitor, soap, training
LOG_LEVEL=INFO    # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
SPONGE_HTTP_PORT=8080
SPONGE_METRICS_PORT=9090

# ================================================================
# AWS CloudWatch Integration (Optional)
# ================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDWATCH_LOG_GROUP=

# ================================================================
# Azure Monitor Integration (Optional)
# ================================================================
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_WORKSPACE_ID=

# ================================================================
# DataDog Integration (Optional)
# ================================================================
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com  # or datadoghq.eu for EU

# ================================================================
# Dynatrace Integration (Optional)
# ================================================================
DYNATRACE_API_TOKEN=
DYNATRACE_ENVIRONMENT_URL=

# ================================================================
# Splunk Integration (Optional)
# ================================================================
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=

# ================================================================
# Prometheus Integration
# ================================================================
PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_PORT=9091

# ================================================================
# Grafana Configuration
# ================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000
GRAFANA_PLUGINS=

# ================================================================
# Redis Configuration (Optional)
# ================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================================================
# Elasticsearch Integration (Optional)
# ================================================================
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=

# ================================================================
# Sumo Logic Integration (Optional)
# ================================================================
SUMOLOGIC_ACCESS_ID=
SUMOLOGIC_ACCESS_KEY=
SUMOLOGIC_API_ENDPOINT=https://api.sumologic.com/api

# ================================================================
# Loggly Integration (Optional)
# ================================================================
LOGGLY_ACCOUNT=
LOGGLY_API_TOKEN=

# ================================================================
# Papertrail Integration (Optional)
# ================================================================
PAPERTRAIL_API_TOKEN=

# ================================================================
# Logentries Integration (Optional)
# ================================================================
LOGENTRIES_API_KEY=
LOGENTRIES_REGION=us  # or eu

# ================================================================
# VelocityAP Integration (Optional)
# ================================================================
VELOCITYAP_API_URL=
VELOCITYAP_API_KEY=
VELOCITYAP_APP_ID=

# ================================================================
# Biometrics DataLOG Integration (Optional)
# ================================================================
DATALOG_API_URL=
DATALOG_API_KEY=
DATALOG_DEVICE_ID=

# ================================================================
# Data Log Viewer Integration (Optional)
# ================================================================
DATALOGVIEWER_API_URL=
DATALOGVIEWER_API_KEY=

# ================================================================
# SolarWinds LEM Integration (Optional)
# ================================================================
SOLARWINDS_API_URL=
SOLARWINDS_USERNAME=
SOLARWINDS_PASSWORD=

# ================================================================
# Sentry Integration (Optional)
# ================================================================
SENTRY_DSN=

# ================================================================
# Machine Learning Configuration
# ================================================================
KNN_N_NEIGHBORS=5
KNN_METRIC=euclidean  # euclidean, manhattan, cosine
KNN_MAX_FEATURES=2000

# ================================================================
# Security & API Keys
# ================================================================
# Generate secure random keys:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_random_64_char_hex_string
API_KEY=change_me_to_another_random_key

# ================================================================
# Notification Settings (Optional)
# ================================================================
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=sponge@example.com
